{
  "name": "wifi-acelerator",
  "version": "0.1.0",
  "description": "Wifi Acelerator - Desktop network monitoring and optimization suite",
  "main": "dist/electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:clean-ports && npm run build:electron && concurrently -k \"npm:dev:frontend\" \"npm:dev:backend\" \"npm:dev:electron\"",
    "dev:mobile": "npm run dev:clean-ports && concurrently -k \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:clean-ports": "kill-port 5173 4000 || true",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "tsx watch backend/server.ts",
    "dev:electron": "wait-on tcp:5173 tcp:4000 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 ELECTRON_BACKEND_PORT=4000 electron dist/electron/main.js",
    "build": "npm run build:frontend && npm run build:backend && npm run build:electron",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:electron": "tsc -p electron/tsconfig.json",
    "start": "cross-env NODE_ENV=production electron dist/electron/main.js",
    "package": "npm run build && electron-builder",
    "test:backend": "tsx --test backend/**/*.test.ts",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend && npm run typecheck:electron",
    "typecheck:frontend": "tsc -p frontend/tsconfig.json --noEmit",
    "typecheck:backend": "tsc -p backend/tsconfig.json --noEmit",
    "typecheck:electron": "tsc -p electron/tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.wifiacelerator.app",
    "productName": "Wifi Acelerator",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.468.0",
    "node-os-utils": "^1.3.7",
    "node-wifi": "^2.0.16",
    "ping": "^0.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0",
    "recharts": "^2.12.7",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "speedtest-net": "^1.6.1",
    "systeminformation": "^5.23.7",
    "tailwind-merge": "^2.5.5"
  },
  "optionalDependencies": {
    "arp-a": "^0.5.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
